@model NotesPageViewModel

@{
    ViewData["Title"] = "Forms";
}

<div class="row mt-4">
    <div class="col-lg-3"></div>
    <div class="col-lg-6">
        <div class="card shadow-lg">
            <div class="card-header">
                <h2>Create New Note</h2>
            </div>
            <div class="card-body">
                <div id="create-note-host">
                    @await Html.PartialAsync("_CreateNoteForm", Model.Form)
                </div>
            </div>
        </div>

        <div class="mt-4"></div>

        <div class="card shadow-lg">
            <div class="card-header">
                <h2>Notes</h2>
            </div>
            <div class="card-body">
                <div id="notes-host">
                    @await Html.PartialAsync("_NotesList", Model.Notes)
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3"></div>
</div>
